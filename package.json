{
  "name": "@spreedly/spreedly-mcp",
  "version": "0.1.0",
  "description": "Spreedly MCP server -- interact with the Spreedly payments API through the Model Context Protocol",
  "type": "module",
  "bin": {
    "spreedly-mcp": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./transport": {
      "import": "./dist/transport/index.js",
      "types": "./dist/transport/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "DISCLAIMER.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:evals": "tsx evals/run.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/bin.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "spreedly",
    "mcp",
    "model-context-protocol",
    "payments",
    "ai",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spreedly/spreedly-mcp.git"
  },
  "homepage": "https://github.com/spreedly/spreedly-mcp#readme",
  "bugs": {
    "url": "https://github.com/spreedly/spreedly-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "openai": "^6.32.0",
    "prettier": "^3.4.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
